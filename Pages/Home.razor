@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://i.pinimg.com/736x/c0/de/7b/c0de7bb93799f5415f3ec03134e412dc.jpg" class="rounded-circle mb-3"
                     width="120" />
                <h3>Arthur Kyldare</h3>
                <p class="text-muted">Escravo CLT PREMIUM ULTRA 8K</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "PIAO",
            Cargo = "FAZ TUDO",
            Inicio = "2026",
            Descricao = "Responsavel por todo trabalho que voce consiga alocar."
        },
        new Experiencia {
            Empresa = "NASA",
            Cargo = "CEO",
            Inicio = "2023", Fim = "2024",
            Descricao = "Responsavel pela administraçao e açao contra atividade alienigenas."
        }
    };
}